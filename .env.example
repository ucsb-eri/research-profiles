# Copy to .env and fill in. Loaded via dotenv when the server/scripts start.
#   cp .env.example .env

# Port the API listens on. Defaults to 3001 if unset (server.js).
# Local dev uses 3001 so it doesn't collide with the Next.js frontend on 3000.
# IMPORTANT: production must pin this to whatever port the reverse proxy expects
# (set it here or in the systemd unit) rather than relying on the default.
PORT=3001

# PostgreSQL connection string (required to serve any data).
# Format: postgres://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgres://postgres:postgres@localhost:5432/research_profiles

# API key for the GRIT LLM endpoint. Only needed to (re)generate faculty
# summaries/keywords via scripts/genSummaries.js — not required to serve the API.
OLLAMA_API_KEY=

# Model used to generate research summaries (scripts/genSummaries.js). Must be a
# model available in your OpenWebUI/Ollama. Defaults to gemma4:31b if unset.
# NOTE: set the model's context window (num_ctx, e.g. 16k–32k) in OpenWebUI so
# long scraped text isn't truncated — that can't be set from here.
SUMMARY_MODEL=gemma4:31b
